# Production Environment Variables Example
# Copy this file to .env before running install.sh or docker-compose up

# -------------------------
# Database Configuration
# -------------------------
# Set a strong, secure password for the Postgres Database
POSTGRES_PASSWORD=your_secure_database_password_here

# The connection string for the backend (used by Next.js in production)
# Note: 'db' is the service name in docker-compose.prod.yml
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@db:5432/postgres

# -------------------------
# Supabase Configuration
# -------------------------
# In a standalone setup without the full Supabase Studio stack, 
# you can use mock values for authentication to work if you don't need external access to the API.
# However, you should generate real JWT secrets in a fully exposed environment.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -------------------------
# Server Configuration
# -------------------------
NODE_ENV=production
PORT=3000
